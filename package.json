{
  "name": "@snowui-design-system/resource-base",
  "version": "1.0.26",
  "description": "SnowUI Design Resource Base - Processes design assets from raw-assets folder, converts black icons to currentColor, generates multi-size bitmaps with 3x retina support, and publishes standardized assets with metadata.",
  "license": "MIT",
  "private": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./assets/icons/snowui/*": "./assets/icons/snowui/*",
    "./assets/icons/phosphor/*": "./assets/icons/phosphor/*",
    "./assets/icons/special/*": "./assets/icons/special/*",
    "./assets/avatars/*": "./assets/avatars/*",
    "./assets/backgrounds/*": "./assets/backgrounds/*",
    "./assets/cursors/*": "./assets/cursors/*",
    "./assets/emoji/*": "./assets/emoji/*",
    "./assets/illustrations/*": "./assets/illustrations/*",
    "./assets/images/*": "./assets/images/*",
    "./assets/logos/*": "./assets/logos/*"
  },
  "files": [
    "src",
    "assets",
    "README.md"
  ],
  "keywords": [
    "snowui",
    "icons",
    "assets",
    "design-system",
    "svg",
    "ui",
    "ux"
  ],
  "scripts": {
    "process": "tsx scripts/process-all.ts",
    "process:icons": "tsx scripts/process-icons.ts",
    "process:materials": "tsx scripts/process-materials.ts",
    "build:mappings": "tsx scripts/build-mappings.ts",
    "sync:iconify": "tsx scripts/sync-iconify.ts",
    "build": "pnpm process && pnpm sync:iconify --mode=auto && pnpm build:mappings && pnpm test:regression",
    "prepublishOnly": "pnpm build",
    "scan:usage": "tsx scripts/scan-usage.ts",
    "check:switch": "tsx scripts/check-switch.ts",
    "test:regression": "tsx scripts/test-regression.ts"
  },
  "devDependencies": {
    "sharp": "^0.33.0",
    "svgo": "^3.0.0",
    "tsx": "^4.7.0"
  }
}
